   "source": [
    "import wandb\n",
    "api = wandb.Api()\n",
    "\n",
    "# iterate over all runs in a project\n",
    "for run in api.runs(\"stereochemistry/RGFN\"):\n",
    "    extension = \".xlxs\"\n",
    "    files = run.files()\n",
    "    for file in files:\n",
    "        if file.name.endswith(extension):\n",
    "            file.delete()\n"
   ]
  }
 ],
